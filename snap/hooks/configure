#!/bin/sh -e

# This hook runs when the snap is configured.
# It reads settings from 'snapctl get' and applies them.

# An example parameter
VALUE=$(snapctl get example-param)
if [ -z "$VALUE" ]; then
  VALUE="default-value"
fi
echo "Setting example-param=$VALUE"
# TODO: Write to your app's config file or environment
# e.g., echo "example-param=$VALUE" >> $SNAP_COMMON/config.env
# The port n8n listens on for HTTP/HTTPS traffic.
VALUE=$(snapctl get port)
if [ -z "$VALUE" ]; then
  VALUE="5678"
fi
echo "Setting port=$VALUE"
# TODO: Write to your app's config file or environment
# e.g., echo "port=$VALUE" >> $SNAP_COMMON/config.env
# Control Tower engine callback URL for deployment status and health checks.
VALUE=$(snapctl get ct-callback-url)
if [ -z "$VALUE" ]; then
  VALUE=""
fi
echo "Setting ct-callback-url=$VALUE"
# TODO: Write to your app's config file or environment
# e.g., echo "ct-callback-url=$VALUE" >> $SNAP_COMMON/config.env
# Control Tower engine snap identifier for this deployment.
VALUE=$(snapctl get ct-snap-name)
if [ -z "$VALUE" ]; then
  VALUE=""
fi
echo "Setting ct-snap-name=$VALUE"
# TODO: Write to your app's config file or environment
# e.g., echo "ct-snap-name=$VALUE" >> $SNAP_COMMON/config.env
# Unique identifier for the node within the Control Tower cluster.
VALUE=$(snapctl get ct-node-id)
if [ -z "$VALUE" ]; then
  VALUE=""
fi
echo "Setting ct-node-id=$VALUE"
# TODO: Write to your app's config file or environment
# e.g., echo "ct-node-id=$VALUE" >> $SNAP_COMMON/config.env
# Control Tower deployment identifier for tracking and management.
VALUE=$(snapctl get ct-deployment-id)
if [ -z "$VALUE" ]; then
  VALUE=""
fi
echo "Setting ct-deployment-id=$VALUE"
# TODO: Write to your app's config file or environment
# e.g., echo "ct-deployment-id=$VALUE" >> $SNAP_COMMON/config.env
