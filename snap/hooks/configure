#!/bin/sh
# Configure hook.
#
# Deliberately NO `set -e`: best-effort only; the hook must never abort and
# fail the deploy.
#
# n8n reads its port live from `snapctl get port` at launch, so when the
# operator changes it (snap set <snap> port=...) we restart the `n8n` daemon to
# pick up the new value. Then hand the automatic ct-* keys to the engine to
# validate/persist (it also restarts the ct-engine sidecar).

export PATH="$SNAP/usr/sbin:$SNAP/usr/bin:$SNAP/sbin:$SNAP/bin:$PATH"

_port="$(snapctl get port 2>/dev/null || true)"
if [ -n "$_port" ]; then
    if snapctl services "${SNAP_INSTANCE_NAME}.n8n" 2>/dev/null | grep -q active; then
        snapctl restart "${SNAP_INSTANCE_NAME}.n8n" || true
    fi
fi

if [ -x "$SNAP/bin/ct-engine-run" ]; then
    "$SNAP/bin/ct-engine-run" hook-configure || true
fi

exit 0
